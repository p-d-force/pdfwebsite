    {
      "field_name": "case_code",
      "display_name": "Case Code",
      "field_type": "text",
      "data_type": "varchar",
      "description": "Unique identifier for the case",
      "is_required": true,
      "validation_rules": ["required", "max:50"],
      "config": {
        "placeholder": "e.g., PRS-2024-001",
        "pattern": "^[A-Z0-9\\-]+$"
      },
      "default_value": "",
      "group_id": 1,
      "display_order": 10,
      "status": "active"
    },
    {
      "field_name": "case_title",
      "display_name": "Case Title",
      "field_type": "text",
      "data_type": "varchar",
      "description": "Descriptive title of the case",
      "is_required": true,
      "validation_rules": ["required", "max:255"],
      "config": {
        "placeholder": "Enter case title"
      },
      "default_value": "",
      "group_id": 1,
      "display_order": 20,
      "status": "active"
    },
    {
