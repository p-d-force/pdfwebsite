      "field_type": "select",
      "data_type": "varchar",
      "description": "Type of case",
      "is_required": true,
      "validation_rules": ["required"],
      "config": {
        "options": {
          "prr": "Public Records Request",
          "foia": "FOIA Request",
          "complaint": "Complaint",
          "appeal": "Appeal",
          "litigation": "Litigation"
